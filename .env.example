# campaignfinance — environment template
# Copy to .env and fill in. .env is gitignored — never commit it.
#
# 1Password mode: Environments SDK. In production, secrets resolve at runtime
# via the SDK (app/op.py -> OnePasswordSettings). Values below may either be set
# directly for local development OR supplied as op:// references resolved by the
# SDK. Never paste real credentials into a committed file.

# --- 1Password Service Account -------------------------------------------
# Token for the 1Password SDK. Required for SDK-based secret resolution.
OP_SERVICE_ACCOUNT_TOKEN=

# --- PostgreSQL (production / staging) -----------------------------------
# For local dev these can be set directly; for production prefer op:// refs.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=campaign_finance
POSTGRES_USER=
POSTGRES_PASSWORD=

# Connection pool tuning (defaults shown).
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_TIMEOUT=30
POSTGRES_POOL_RECYCLE=3600

# --- Logging (PaperTrail) ------------------------------------------------
PAPERTRAIL_HOST=logs4.papertrailapp.com
PAPERTRAIL_PORT=33096
